    <Element Body="Switch between themes and see how controls look and feel in various themes" Title="Change themes" Section="Section-02">
      <Style linktype="NoLink" />
    </Element>
    <Element Body="Find examples and application scenarios for available controls" Title="Quick search" Section="Section-02">
      <Style linktype="NoLink" />
    </Element>
    <Element Body="Flexible scalability options from session and IP stickiness to no-stickiness and from In-Process state management to an application server and a state server." Title="Unlimited Scalability" Section="Section-03" Link="http://www.visualwebgui.com/Gizmox/Technology/Scalabilityanddeploymenteconomy/tabid/626/Default.aspx">
