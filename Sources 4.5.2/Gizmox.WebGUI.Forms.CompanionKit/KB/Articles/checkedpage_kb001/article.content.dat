<?xml version="1.0" encoding="utf-8"?>
<Data CreatedBy="admin" CreatedOn="634110121829750596" UpdatedBy="admin" UpdatedOn="634118463866165026">
  <Properties />
  <Nodes>
    <Header Code="HeaderElement1" Type="Subtitle" ShowInTOC="0"><![CDATA[The example]]></Header>
    <Paragraph Code="ParagraphElement1"><![CDATA[<p>Click on 'Demo CheckBox' CheckBox and the label will indicates checked state of the CheckBox.&nbsp;Set CheckBox Checked property as true and&nbsp;the label will contains 'CheckBox is checked!', otherwise, the label contains 'CheckBox is unchecked!'</p>]]></Paragraph>
    <Header Code="HeaderElement2" Type="Subtitle" ShowInTOC="0"><![CDATA[General Info]]></Header>
    <Paragraph Code="ParagraphElement3" />
    <Paragraph Code="ParagraphElement4"><![CDATA[<p>The Visual WebGui <em>CheckBox </em>contains the <em>Checked </em>property and <em>CheckedChange </em>event for manipulating with checked indicator. The <em>Checked </em>property indicates whether <em>CheckBox </em>is checked. The <em>CheckedChange </em>event invoke when <em>Checked </em>property are changed.</p>]]></Paragraph>
    <Paragraph Code="ParagraphElement2" />
  </Nodes>
</Data>
