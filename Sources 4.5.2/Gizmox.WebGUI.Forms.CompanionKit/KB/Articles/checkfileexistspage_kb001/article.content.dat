<?xml version="1.0" encoding="utf-8"?>
<Data CreatedBy="admin" CreatedOn="634082283226453327" UpdatedBy="admin" UpdatedOn="634082284170246791">
  <Properties />
  <Nodes>
    <Header Code="HeaderElement1" Type="Subtitle" ShowInTOC="0"><![CDATA[The example]]></Header>
    <Paragraph Code="ParagraphElement1"><![CDATA[<p>Check/Uncheck the 'Enable CheckFileExists for OpenFileDialog' CheckBox and click on the 'Open OpenFileDialog with enable/disable CheckFileExists property' button and upload file dialog will be opened. Click on the 'Add' button and the <em>OpenFileDialog </em>will be opened. Enter file name and click on the 'Open' button. If the main CheckBox is checked, the Dialog checks whether entered file exists if it does not exist the dialog displays a warning message. Otherwise dialog doesn't check whether entered file exists.</p>]]></Paragraph>
    <Header Code="HeaderElement2" Type="Subtitle" ShowInTOC="0"><![CDATA[General Info]]></Header>
    <Paragraph Code="ParagraphElement2"><![CDATA[<p>The Visual WebGui <em>OpenFileDialog </em>dialog box <em>CheckFileExists </em>property that indicates whether the dialog box displays a warning if the user specifies a file name that does not exist.</p>]]></Paragraph>
  </Nodes>
</Data>