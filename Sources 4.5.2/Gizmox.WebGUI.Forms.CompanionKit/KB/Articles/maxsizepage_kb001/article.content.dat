<?xml version="1.0" encoding="utf-8"?>
<Data CreatedBy="admin" CreatedOn="634082500823408187" UpdatedBy="admin" UpdatedOn="634082501758934712">
  <Properties />
  <Nodes>
    <Header Code="HeaderElement1" Type="Subtitle" ShowInTOC="0"><![CDATA[The example]]></Header>
    <Paragraph Code="ParagraphElement1"><![CDATA[<p>Enter maximum font size into the 'Maximum font size for label' TextBox and click on the 'Open FontDialog to change font of the label' button. The <em>FontDialog </em>will be opened with limited with maximum font sizes that can be selected. If you try to set size more than the set maximum size, the error message will be shown.</p>]]></Paragraph>
    <Header Code="HeaderElement2" Type="Subtitle" ShowInTOC="0"><![CDATA[General Info]]></Header>
    <Paragraph Code="ParagraphElement2"><![CDATA[<p>The Visual WebGui <em>FontDialog </em>dialog box contains the <em>MaxSize </em>property that represents the maximum point size a user can select.</p>]]></Paragraph>
  </Nodes>
</Data>