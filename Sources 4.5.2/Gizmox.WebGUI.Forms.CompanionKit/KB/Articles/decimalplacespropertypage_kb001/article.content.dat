<Data CreatedBy="admin" CreatedOn="634088383460513346" UpdatedBy="admin" UpdatedOn="634088384428025730">
  <Properties />
  <Nodes>
    <Header Code="HeaderElement1" Type="Subtitle" ShowInTOC="0"><![CDATA[The example]]></Header>
    <Paragraph Code="ParagraphElement1"><![CDATA[<p>Enter number of decimal places into the 'Decimal places' <em>NumericUpDown </em>and number of decimal places to display in the spin box of the demonstrated <em>NumericUpDown </em>will be changed respectively. </p>]]></Paragraph>
    <Header Code="HeaderElement2" Type="Subtitle" ShowInTOC="0"><![CDATA[General Info]]></Header>
    <Paragraph Code="ParagraphElement2"><![CDATA[<p>The Visual WebGui <em>NumericUpDown </em>contains the <em>DecimalPlaces </em>property that represents the number of decimal places to display in the spin box (also known as an up-down control).</p>]]></Paragraph>
  </Nodes>
</Data>