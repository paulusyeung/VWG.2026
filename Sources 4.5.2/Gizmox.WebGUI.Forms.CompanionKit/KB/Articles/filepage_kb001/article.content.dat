<?xml version="1.0" encoding="utf-8"?>
<Data CreatedBy="admin" CreatedOn="634081733871319668" UpdatedBy="admin" UpdatedOn="634082244260215758">
  <Properties />
  <Nodes>
    <Header Code="HeaderElement1" Type="Subtitle" ShowInTOC="0"><![CDATA[The example]]></Header>
    <Paragraph Code="ParagraphElement1"><![CDATA[<p>Click on the 'Open selection file dialog with Visual WebGui Upload Dialog' button and the upload file dialog will be opened. Click on the 'Add' button and the <em>OpenFileDialog </em>will be opened. Select file and click on the 'Open' button.  Original and temporary file name and size of the uploaded file will be shown in the 'Original name of the selected file', 'Selected file name of the File property' and 'Selected file size of the File property' TextBoxes respectively.</p>]]></Paragraph>    
    <Header Code="HeaderElement2" Type="Subtitle" ShowInTOC="0"><![CDATA[General Info]]></Header>
    <Paragraph Code="ParagraphElement2"><![CDATA[<p>The <em>OpenFileDialog </em>dialog box contains the <em>File </em>property that represents the <em>FileHandle </em>of the current selected file in the Visual WebGui <em>OpenFileDialog </em>dialog box.</p>]]></Paragraph>
  </Nodes>
</Data>
