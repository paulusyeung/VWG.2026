<?xml version="1.0" encoding="utf-8"?>
<Data CreatedBy="admin" CreatedOn="634099626866246288" UpdatedBy="admin" UpdatedOn="634099647994279429">
  <Properties />
  <Nodes>
    <Header Code="HeaderElement1" Type="Subtitle" ShowInTOC="0"><![CDATA[The example]]></Header>
    <Paragraph Code="ParagraphElement1"><![CDATA[<p>The example contains the Visual WebGui <em>FlashBox </em>control for browsing Flash animation. </p>]]></Paragraph>
    <Header Code="HeaderElement2" Type="Subtitle" ShowInTOC="0"><![CDATA[General Info]]></Header>
    <Paragraph Code="ParagraphElement2"><![CDATA[<p>The example demonstrates how to set essential parameters to embed properly a Flash animation. The parameters should be provided with Visual Studio designer.</p><p>To browser Flash animation on the Visual WebGui <em>Form</em>, follow these steps:</p><ol><li>Drag FlashBox control on the Form in the Visual Studio Designer.</li></ol>]]></Paragraph>
    <Image Code="ImageElement1" Resource="DragFlashBox.png" Type="Resource" />
    <Paragraph Code="ParagraphElement3"><![CDATA[<ol start="2"><li>Set location for the control.</li></ol>]]></Paragraph>
    <Image Code="ImageElement2" Resource="LocationFlashBox.png" Type="Resource" />
    <Paragraph Code="ParagraphElement4"><![CDATA[<ol start="3"><li>Set size for the control.</li></ol>]]></Paragraph>
    <Image Code="ImageElement3" Resource="SizeFlashBox.png" Type="Resource" />
    <Paragraph Code="ParagraphElement5"><![CDATA[<ol start="4"><li>Set value 'http://download.macromedia.com/pub/shockwave/cabs/flash/swflash.cab#version=6,0,0,0&quot; into the FlashBox.CodeBase property.</li></ol>]]></Paragraph>
    <Image Code="ImageElement4" Resource="CodeBaseFlashBox.png" Type="Resource" />
    <Paragraph Code="ParagraphElement6"><![CDATA[<ol start="5"><li>Set URL to a Flash animation into the FlashBox.Movie property.</li></ol>]]></Paragraph>
    <Image Code="ImageElement5" Resource="MovieFlashBox.png" Type="Resource" />
    <Paragraph Code="ParagraphElement7"><![CDATA[<ol start="6"><li>Set parameters for FlashBox Control. It can be done with several way:</li></ol><p>&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp; a.&nbsp;	With designer :<br />&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp; -&nbsp;&nbsp; Select Parameters property in the Properties Windows</p>]]></Paragraph>
    <Image Code="ImageElement6" Resource="ParametersFlashBox.png" Type="Resource" />
    <Paragraph Code="ParagraphElement8"><![CDATA[<p>&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; -&nbsp; Click on the '...'&nbsp; button and 'ObjectBoxParameters Collection Editor' will be opened</p>]]></Paragraph>
    <Image Code="ImageElement7" Resource="ParametersEditor.png" Type="Resource" />
    <Paragraph Code="ParagraphElement9"><![CDATA[<p>&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp; -&nbsp; Click on Add button will be added a new parameter</p>]]></Paragraph>
    <Image Code="ImageElement8" Resource="AddParameterInEditor.png" Type="Resource" />
    <Paragraph Code="ParagraphElement10"><![CDATA[<p>&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp; -&nbsp; Select the parameter in section 'Members' and property Name and Value will be displayed in the '&lt;Parameter name&gt; properties' section. Set the name and value for added parameters</p>]]></Paragraph>
    <Image Code="ImageElement9" Resource="SetNameAndValueParameters.png" Type="Resource" />
    <Paragraph Code="ParagraphElement11"><![CDATA[<p>&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp; -&nbsp;	To remove parameter, select the parameter in the 'Members' section and click on the 'Remove' button in the 'ObjectBoxParameters Collection Editor'</p>]]></Paragraph>
    <Image Code="ImageElement10" Resource="RemoveParameter.png" Type="Resource" />
    <Paragraph Code="ParagraphElement12"><![CDATA[<p>&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp; b.&nbsp;	With code:<br />&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp; -&nbsp;	Call method FlashBox.AddParameter( &lt;Parameter Name&gt;, &lt;Parameter Value&gt;)</p><p>&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp; <strong>C#:</strong></p>]]></Paragraph>
    <Code Code="CodeElement1" Language="csharp"><![CDATA[this.demoFlashBox.AddParameter("FlashVars", "&dataURL=../../../../../../Resources/Flash/FC_2_3_DATA.xml");]]></Code>
    <Paragraph Code="ParagraphElement14"><![CDATA[<p><strong>&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp; Visaul Basic:</strong></p>]]></Paragraph>
    <Code Code="CodeElement2" Language="vbnet"><![CDATA[Me.demoFlashBox.AddParameter("FlashVars", "&dataURL=../../../../../../Resources/Flash/FC_2_3_DATA.xml")]]></Code>
    <Paragraph Code="ParagraphElement13" />
    <Paragraph Code="ParagraphElement15"><![CDATA[<p>&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp; - &nbsp;	Or call 'Add' method for FlashBox.Parameters collection.</p><p>&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp; <strong>C#:</strong></p>]]></Paragraph>
    <Code Code="CodeElement3" Language="csharp"><![CDATA[this.demoFlashBox.Parameters.Add("FlashVars", "&dataURL=../../../../../../Resources/Flash/FC_2_3_DATA.xml");]]></Code>
    <Paragraph Code="ParagraphElement16"><![CDATA[<p><strong>&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp; Visual Basic:</strong></p>]]></Paragraph>
    <Code Code="CodeElement4" Language="vbnet"><![CDATA[Me.demoFlashBox.Parameters.Add("FlashVars", "&dataURL=../../../../../../Resources/Flash/FC_2_3_DATA.xml")]]></Code>
    <Paragraph Code="ParagraphElement17"><![CDATA[<ol start="7"><li>Start application.</li></ol>]]></Paragraph>
  </Nodes>
</Data>