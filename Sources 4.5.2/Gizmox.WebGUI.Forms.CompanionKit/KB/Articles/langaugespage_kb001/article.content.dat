<Data CreatedBy="admin" CreatedOn="634086829659355205" UpdatedBy="admin" UpdatedOn="634090170571454148">
  <Properties />
  <Nodes>
    <Header Code="HeaderElement1" Type="Subtitle" ShowInTOC="0"><![CDATA[The example]]></Header>
    <Paragraph Code="ParagraphElement1"><![CDATA[<p>Select language in the 'Select language' ComboBox and language of the <em>DateTimePicker </em>will be changed respectively.</p>]]></Paragraph>
    <Header Code="HeaderElement2" Type="Subtitle" ShowInTOC="0"><![CDATA[General Info]]></Header>
    <Paragraph Code="ParagraphElement2"><![CDATA[<p>The Visual WebGui <em>DateTimePicker </em>supports a large number of languages and cultures. By defining the specific culture in the application, you can have the <em>DateTimePicker </em>display the dates and times in your language and culture.</p>]]></Paragraph>
  </Nodes>
</Data>