<?xml version="1.0" encoding="utf-8"?>
<Data CreatedBy="admin" CreatedOn="634377067733061852" UpdatedBy="admin" UpdatedOn="634381571632336460">
  <Properties />
  <Nodes>
    <Header Code="HeaderElement1" Type="Subtitle" ShowInTOC="1"><![CDATA[The example]]></Header>
    <Paragraph Code="ParagraphElement1"><![CDATA[<p>Choose one of the <em>ComboBox </em>items which represents&nbsp;icon that will be shown within the <em>MessageBox </em>window. Press <em>Button </em>to show <em>MessageBox </em>window. <em>MessageBox </em>window modal mask can be turned On/Off by switching the 'Show Modal Mask' <em>CheckBox</em>.</p>]]></Paragraph>
    <Header Code="HeaderElement2" Type="Subtitle" ShowInTOC="1"><![CDATA[General Info]]></Header>
    <Paragraph Code="ParagraphElement2"><![CDATA[<p><em>MessageBox&nbsp;</em>icon for <em>MessageBox </em>window can be simply set by respectively passing parameters to suitable <em>MessageBox </em>constructor called.</p><p><em>MessageBox </em>constructor parameters:</p><p><strong>enmIcon:</strong> specifies constants defining which&nbsp;icon to display on a <em>MessageBox </em>window;<br /><strong>blnShowModalMask:</strong> determines whether a form has a modal mask when modal;<br /><strong>objEventHandler:</strong> an System.EventHandler function that is called when MessageBox window is closed.</p>]]></Paragraph>
  </Nodes>
</Data>