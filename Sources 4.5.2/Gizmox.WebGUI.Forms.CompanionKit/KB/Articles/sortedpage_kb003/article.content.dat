<Data CreatedBy="admin" CreatedOn="634127360554981479" UpdatedBy="admin" UpdatedOn="634127361223735759">
  <Properties />
  <Nodes>
    <Header Code="HeaderElement1" Type="Subtitle" ShowInTOC="0"><![CDATA[The example]]></Header>
    <Paragraph Code="ParagraphElement1"><![CDATA[<p>Check the 'Turn on Sorted property for ListBox' CheckBox, <em>ListBox </em>items will be sorted alphabetically. Uncheck the CheckBox these <em>ListBox </em>items will be unsorted.</p>]]></Paragraph>
    <Header Code="HeaderElement2" Type="Subtitle" ShowInTOC="0"><![CDATA[General Info]]></Header>
    <Paragraph Code="ParagraphElement2"><![CDATA[<p>The Visual WebGui <em>ListBox </em>contains the <em>Sorted </em>property that indicates whether the items in the <em>ListBox </em>are sorted alphabetically.</p>]]></Paragraph>
  </Nodes>
</Data>
