<configuration>
  
  <WebGUI>


    <Applications>
      <Application Code="C1ReportViewerForm" Type="ComponentOneSampleAppsCS.C1ReportViewerForm, ComponentOneSampleAppsCS" Authentication="Default" Stateless="False" ForceSSL="False" />
    </Applications>

    <Includes>
      <Include IncludeName="C1EventsCalendarForm" IncludeType="Script" SourceType="Resource" MinimalSource="ComponentOneSampleAppsCS.C1EventsCalendarForm.js" Source="ComponentOneSampleAppsCS.C1EventsCalendarForm.js" Assembly="ComponentOneSampleAppsCS" />
    </Includes>

  </WebGUI>
  
  <system.webServer>
    <validation validateIntegratedModeConfiguration="false" />
    <handlers>
      <add name="*.wgx_*" path="*.wgx" verb="*" type="Gizmox.WebGUI.Server.Router,Gizmox.WebGUI.Server,Version=4.0.5701.0,Culture=neutral,PublicKeyToken=3de6eb684226c24d" preCondition="integratedMode,runtimeVersionv4.0" />
    </handlers>
  </system.webServer>

</configuration>
