			mobjTracingThreshold = new WGTracingThresholdSwitch("VWG_TracingThresholdSwitch", "Define the tracing threshold level.");
			mobjDisableObscuringSwitch = new BooleanSwitch("VWG_DisableObscuringSwitch", "Enable client scripts obscuring and compacting.");
			mobjEnableClientShortcuts = new BooleanSwitch("VWG_EnableClientShortcutsSwitch", "Enable client key shortcuts.");
