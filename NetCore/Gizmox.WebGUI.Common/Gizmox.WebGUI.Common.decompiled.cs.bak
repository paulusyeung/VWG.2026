		private Type[] GetRegisterdControls(string strControlType)
		{
			if (!strControlType.Contains("*"))
			{
				/*OpCode not supported: LdMemberToken*/;
				Type type = Type.GetType(CommonUtils.GetFullTypeName(strControlType), throwOnError: false);
				if (!(type != null))
				{
					/*OpCode not supported: LdMemberToken*/;
				}
				else
