				{
					/*OpCode not supported: LdMemberToken*/;
				}
				else if (!fileInfo.Exists)
				{
					/*OpCode not supported: LdMemberToken*/;
				}
				else
				{
					text = fileInfo.Name;
					DirectoryInfo directoryInfo2 = fileInfo.Directory;
					while (true)
