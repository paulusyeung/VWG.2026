namespace Gizmox.WebGUI.Common.Exceptions
{
	[Serializable]
	public class LogonException : Exception
	{
		public LogonException()
		{
		}

		public LogonException(string strMessage)
			: base(strMessage)
		{
		}

		public LogonException(string strMessage, Exception objInnerException)
			: base(strMessage, objInnerException)
		{
		}

		public static bool IsLogonException(Exception objException)
		{
			for (Exception ex = objException; ex != null; ex = ex.InnerException)
			{
				/*OpCode not supported: LdMemberToken*/;
				if (ex is LogonException)
				{
					return true;
				}
			}
			return false;
		}
	}
