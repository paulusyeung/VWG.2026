		private bool GB;

		private bool HB;

		private bool IB;

		private bool JB;

		public JQTTokenReader(TokenContext objTokenContext, TextReader objSource)
			: base(objTokenContext, objSource)
		{
		}

		public JQTTokenReader(TokenContext objTokenContext, Stream objSource)
			: base(objTokenContext, objSource)
		{
		}

		public JQTTokenReader(TokenContext objTokenContext, string objSource)
			: base(objTokenContext, objSource)
		{
		}

		protected override Token ReadToken()
		{
			Token token = null;
			char currentCharecter = base.CurrentCharecter;
			if (!IB)
			{
				/*OpCode not supported: LdMemberToken*/;
				if (!GB)
				{
					/*OpCode not supported: LdMemberToken*/;
					if (!HB)
					{
						/*OpCode not supported: LdMemberToken*/;
					}
					else if (IsStartQuoteString(currentCharecter))
					{
						IB = true;
						token = CreateToken(base.CurrentContext, TokenType.Unkown, Read(1));
					}
				}
				else if (JB)
				{
					IB = true;
					token = CreateToken(base.CurrentContext, TokenType.Unkown, Read(1));
				}
				else if (IsStartQuoteString(currentCharecter))
				{
					if (base.NextCharecter != '#')
					{
						/*OpCode not supported: LdMemberToken*/;
						GB = false;
					}
					else
					{
						JB = true;
						token = CreateToken(base.CurrentContext, TokenType.Unkown, Read(1));
					}
				}
			}
			else
			{
				string strTokenContent = ReadQuoteString().Replace("\"", "");
				TokenContext currentContext = base.CurrentContext;
				int enmType;
				if (GB)
				{
					/*OpCode not supported: LdMemberToken*/;
					enmType = 72;
				}
				else
				{
					enmType = 73;
				}
				token = CreateToken(currentContext, (TokenType)enmType, strTokenContent);
				IB = false;
				GB = false;
				JB = false;
				GB = false;
				HB = false;
			}
			if (token != null)
			{
				/*OpCode not supported: LdMemberToken*/;
			}
			else
			{
				token = base.ReadToken();
			}
			return token;
		}

		private bool IsHash(char chrCurrent)
		{
			return chrCurrent == '#';
		}

		protected override Token HandleIdentifier(string strIdentifier)
		{
			if (!IsJQTRegtemplate(strIdentifier))
			{
				/*OpCode not supported: LdMemberToken*/;
				if (!IsJQTCallTemplate(strIdentifier))
				{
					/*OpCode not supported: LdMemberToken*/;
					return base.HandleIdentifier(strIdentifier);
				}
				HB = true;
				return CreateToken(base.CurrentContext, TokenType.JsKeyword, strIdentifier);
			}
			GB = true;
			return CreateToken(base.CurrentContext, TokenType.JsKeyword, strIdentifier);
		}

		private bool IsJQTRegtemplate(string strWord)
		{
			return strWord == "jqtregtemplate";
		}

		private bool IsJQTCallTemplate(string strWord)
		{
			return strWord == "jqtcalltemplate";
		}
	}
}
namespace Gizmox.WebGUI.Common.Tokens.Html
{
	public class HtmlToken : Token
	{
		private HtmlTokenReader M;

		public override TokenReader SubTokens
		{
			get
			{
				if (M != null)
				{
					/*OpCode not supported: LdMemberToken*/;
				}
				else
				{
					M = new HtmlTokenReader(base.Context, new StringReader(base.Content));
				}
				return M;
			}
		}

