				if (xmlElement.GetAttribute("Mode").ToLower().Equals("none"))
				{
					/*OpCode not supported: LdMemberToken*/;
				}
				else
				{
					flag = true;
				}
			}
			this["Authentication.UseAuthentication"] = flag;
		}

