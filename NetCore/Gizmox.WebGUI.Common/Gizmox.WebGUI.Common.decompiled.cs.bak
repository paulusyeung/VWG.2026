			string[] array = strControlType.Split(',');
			if (array.Length <= 1)
			{
				/*OpCode not supported: LdMemberToken*/;
			}
			else
			{
				string text = array[0].Replace(".*", string.Empty).Trim();
				Assembly assembly = Assembly.Load(CommonUtils.GetFullAssemblyName(array[1].Trim()));
				if (!(assembly != null))
				{
					/*OpCode not supported: LdMemberToken*/;
				}
				else
