		{
			if (!(base.CurrentContext is XmlTokenContext xmlTokenContext))
			{
				/*OpCode not supported: LdMemberToken*/;
				return base.ReadAttributeValueToken(strAttributeName, strAttributeValue);
			}
			if (!(strAttributeName == "name"))
			{
