		private string GetLogonUserName(XmlNode objNode)
		{
			string result = "admin";
			if (!(objNode is XmlElement xmlElement))
			{
				/*OpCode not supported: LdMemberToken*/;
			}
			else if (!xmlElement.HasAttribute("UserName"))
			{
