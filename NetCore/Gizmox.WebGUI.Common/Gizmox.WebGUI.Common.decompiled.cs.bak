		protected override string GetSpecificResourceHandle()
		{
			string file = File;
			if (file.StartsWith("~/"))
			{
				/*OpCode not supported: LdMemberToken*/;
				HostContext current = HostContext.Current;
				if (current == null)
				{
					/*OpCode not supported: LdMemberToken*/;
