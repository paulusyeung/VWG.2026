						}
						/*OpCode not supported: LdMemberToken*/;
						text = $"{directoryInfo2.Name}.{text}";
						directoryInfo2 = directoryInfo2.Parent;
					}
				}
			}
			return text;
		}

		private void PreloadRegisterdControlsResources()
