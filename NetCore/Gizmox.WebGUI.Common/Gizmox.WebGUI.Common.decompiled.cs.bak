	public class SkinResourceHandle : ResourceHandle
	{
		public override bool IsServerResource => true;

		protected internal override bool IsResourceDataSupported => true;

		public SkinResourceHandle(Type objSkinType, string strResourceName)
		{
			Type type = null;
			if (!typeof(Skin).IsAssignableFrom(objSkinType))
			{
				/*OpCode not supported: LdMemberToken*/;
				type = SkinFactory.GetSkinType(objSkinType);
			}
			else
			{
				type = objSkinType;
			}
			if (type == null)
			{
				throw new ArgumentNullException("objSkinType", "SkinResourceHandle requires a valid skin type.");
			}
			File = SkinFactory.GetSkinResourcePath(type, strResourceName);
		}

		public SkinResourceHandle(Skin objSkin, string strResourceName)
		{
			if (objSkin == null)
			{
				throw new ArgumentNullException("objSkin", "SkinResourceHandle requires a valid skin.");
			}
			File = objSkin.GetResourcePath(strResourceName);
		}

		[Obsolete("This constructor no longer works as skinning now requires a skin instance or type (see other constructors).")]
		public SkinResourceHandle(string strResourceName)
		{
		}

		public SkinResourceHandle()
		{
		}

		public override Stream ToStream()
		{
			IContext current = VWGContext.Current;
			if (current == null)
			{
				/*OpCode not supported: LdMemberToken*/;
				return null;
			}
			MemoryStream memoryStream = new MemoryStream();
			SkinFactory.WriteSkinResource(current, memoryStream, SkinFactory.GetSkinResourceNameFromPath(File), new NameValueCollection());
			memoryStream.Position = 0L;
			return memoryStream;
		}

		protected override string GetSpecificResourceHandle()
		{
			return File;
		}

		protected internal override string GetUniqueIdentifier()
		{
			return $"Skins.{File}";
		}
	}
