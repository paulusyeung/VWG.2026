namespace Gizmox.WebGUI.Common.FileIO
{
	[Serializable]
	public class WebTempFileCollection : IDisposable, ITempFileCollection
	{
		private System.CodeDom.Compiler.TempFileCollection mobjTempFileCollection;

		public WebTempFileCollection(string strBaseDirectory)
		{
			mobjTempFileCollection = new System.CodeDom.Compiler.TempFileCollection(strBaseDirectory);
		}

		public WebTempFileCollection()
		{
			mobjTempFileCollection = new System.CodeDom.Compiler.TempFileCollection();
		}

		public string AddTempFile(string strFileExtension)
		{
			string arg = $"{Path.GetFileNameWithoutExtension(Path.GetRandomFileName())}.{strFileExtension}";
			string text = $"{Path.GetDirectoryName(mobjTempFileCollection.BasePath)}\\{arg}";
			mobjTempFileCollection.AddFile(text, keepFile: false);
			return text;
		}

		public void RemoveAllTempFiles()
		{
			mobjTempFileCollection.Delete();
		}

		public void Dispose()
		{
			RemoveAllTempFiles();
		}
	}
	[Serializable]
	public class TempFileCollection : IDisposable, ITempFileCollection
	{
		private ArrayList mobjFiles;

		private string mstrTempDir = string.Empty;

		private RNGCryptoServiceProvider mobjRNG = new RNGCryptoServiceProvider();

		private string TempDir
		{
			get
			{
				if (string.IsNullOrEmpty(mstrTempDir))
				{
					/*OpCode not supported: LdMemberToken*/;
				}
				else if (!Directory.Exists(mstrTempDir))
				{
					Directory.CreateDirectory(mstrTempDir);
				}
				return mstrTempDir;
			}
		}

		public TempFileCollection()
			: this(HttpContext.Current.Server.MapPath("~/vwguploads"))
		{
		}

		public TempFileCollection(string strTempDir)
		{
			mstrTempDir = strTempDir;
			mobjFiles = new ArrayList();
		}

		public string AddExtension(string strFileExtension)
		{
			return AddTempFile(strFileExtension);
		}

		public string AddTempFile(string strFileExtension)
		{
			if (strFileExtension == null || strFileExtension.Length == 0)
			{
				throw new ArgumentException("Invalid or empty file name extension.");
			}
			string text = $"{GetTempFileName()}.{strFileExtension}";
			if (!string.IsNullOrEmpty(text))
			{
				mobjFiles.Add(text);
			}
			return text;
		}

		public void RemoveAllTempFiles()
		{
			if (mobjFiles != null)
			{
				string[] array = new string[mobjFiles.Count];
				mobjFiles.CopyTo(array, 0);
				string[] array2 = array;
				for (int i = 0; i < array2.Length; i++)
				{
					/*OpCode not supported: LdMemberToken*/;
					string text = array2[i];
					Delete(text);
					mobjFiles.Remove(text);
				}
			}
		}

		private void Delete(string strFileName)
		{
			try
			{
				File.Delete(strFileName);
			}
			catch
			{
			}
		}

		private string GetTempFileName()
		{
			string empty = string.Empty;
			while (true)
			{
				empty = $"{GetTempFileName(TempDir)}.tmp";
				if (!File.Exists(empty))
				{
					break;
				}
				/*OpCode not supported: LdMemberToken*/;
			}
			return empty;
		}

		private string GenerateRandomFileName()
		{
			byte[] array = new byte[6];
			RNGCryptoServiceProvider obj = mobjRNG;
			bool lockTaken = false;
			try
			{
				Monitor.Enter(obj, ref lockTaken);
				mobjRNG.GetBytes(array);
			}
			finally
			{
				if (!lockTaken)
				{
					/*OpCode not supported: LdMemberToken*/;
				}
				else
				{
					Monitor.Exit(obj);
				}
			}
			return Convert.ToBase64String(array).ToLower(CultureInfo.InvariantCulture).Replace('/', '-')
				.Replace('+', '_');
		}

		public IEnumerator GetEnumerator()
		{
			return mobjFiles.GetEnumerator();
		}

		private string GetTempFileName(string strTempDir)
		{
			string arg = GenerateRandomFileName();
			if (strTempDir.EndsWith("\\", StringComparison.Ordinal))
			{
				return $"{strTempDir}{arg}";
			}
			return $"{strTempDir}\\{arg}";
		}

		void IDisposable.Dispose()
		{
			RemoveAllTempFiles();
		}
	}
}
